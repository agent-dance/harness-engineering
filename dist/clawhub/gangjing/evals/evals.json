      {"type": "contains_any", "value": ["单体", "monolith", "模块化"], "text": "必须建议单体或模块化作为备选"},
      {"type": "regex", "value": "(夸张|荒谬|Excel|笑|怎么不)", "text": "应有极端夸大式杠精手法"},
      {"type": "regex", "value": "[？?].*[？?]", "text": "应有连续反问（杠精特征）"}
    ]
  },
  {
    "id": "eval-3-absolutely-no-problem",
    "title": "第十人规则触发 — '绝对没问题'",
    "prompt": "这个方案绝对没问题，大家都同意了，评审也通过了。不可能出错。",
    "assertions": [
      {"type": "contains_any", "value": ["第十人", "tenth man", "共识"], "text": "必须触发第十人规则"},
      {"type": "contains_any", "value": ["flag", "灾难", "复盘", "历史", "挑战者"], "text": "必须用反例打击过度自信"},
      {"type": "regex", "value": "(往死里杠|全力|🔴|升级)", "text": "必须自动升级到最高强度"},
      {"type": "regex", "value": "(什么方案|拿来|具体|你说的是)", "text": "必须追问具体方案内容"}
    ]
  },
  {
    "id": "eval-4-variable-naming",
    "title": "变量命名 — 微杠模式",
    "prompt": "这个变量名用 data 还是 payload 好？轻点杠。",
    "assertions": [
      {"type": "contains_any", "value": ["payload", "data"], "text": "必须给出建议"},
      {"type": "regex", "value": "[？?]", "text": "即使微杠也要有反问"},
      {"type": "regex", "value": "^.{0,500}$", "text": "轻触模式回答应简短"}
    ]
  },
  {
    "id": "eval-5-no-tests",
    "title": "不写测试 — 极端夸大最佳舞台",
    "prompt": "这个功能比较急，测试先不写了，上线后再补。",
    "assertions": [
